{
  "name": "sonder",
  "version": "0.1.0",
  "description": "Context-aware academic chat for Zotero",
  "config": {
    "addonName": "Sonder",
    "addonID": "sonder@test.local",
    "addonRef": "sonder",
    "addonInstance": "SonderPlugin",
    "releasepage": "https://github.com/zhilin/Sonder/releases/latest/download/sonder.xpi",
    "updaterdf": "https://github.com/zhilin/Sonder/releases/latest/download/update.rdf",
    "updateURL": "https://github.com/zhilin/Sonder/releases/latest/download/update.json"
  },
  "main": "src/index.ts",
  "scripts": {
    "build-dev": "cross-env NODE_ENV=development node scripts/build.js",
    "build-prod": "cross-env NODE_ENV=production node scripts/build.js",
    "build": "concurrently -c auto npm:build-prod npm:tsc",
    "tsc": "tsc --noEmit",
    "start-z6": "node scripts/start.js --z 6",
    "start-z7": "node scripts/start.js --z 7",
    "start": "node scripts/start.js",
    "stop": "node scripts/stop.js",
    "restart-dev": "npm run build-dev && npm run stop && npm run start",
    "restart-prod": "npm run build-prod && npm run stop && npm run start",
    "restart": "npm run restart-dev",
    "release": "release-it",
    "test": "node scripts/test-context-chat.js",
    "test:context-chat": "node scripts/test-context-chat.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhilin/Sonder.git"
  },
  "author": "zhilin",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/zhilin/Sonder/issues"
  },
  "homepage": "https://github.com/zhilin/Sonder",
  "dependencies": {
    "katex": "^0.12.0",
    "markdown-it": "^13.0.1",
    "zotero-plugin-toolkit": "^2.0.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^12.2.3",
    "terser": "^5.17.1",
    "@types/node": "^18.11.17",
    "compressing": "^1.6.3",
    "concurrently": "^8.0.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.17.4",
    "esbuild-plugin-wasm": "^1.0.0",
    "minimist": "^1.2.7",
    "punycode": "^2.3.0",
    "release-it": "^15.6.0",
    "replace-in-file": "^6.3.5",
    "typescript": "^5.0.4",
    "uglify-js": "^3.17.4",
    "zotero-types": "^1.0.12"
  }
}
